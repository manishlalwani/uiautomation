<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>

        <Console name="Console">
            <PatternLayout
                pattern="%d{HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>

        <File name="AutomationFile"
              fileName="logs/automation.log">

            <PatternLayout
                pattern="%d %-5level %c{1} - %msg%n"/>

        </File>

    </Appenders>

    <Loggers>

        <Root level="info">

            <AppenderRef ref="Console"/>
            <AppenderRef ref="AutomationFile"/>

        </Root>

    </Loggers>

</Configuration>